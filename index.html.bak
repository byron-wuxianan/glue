<script>
// ==================== AUTH & PERSISTENCE ====================
const STORAGE_KEY = 'glue_system_data_v1';
const USERS_KEY = 'glue_users_v1';
const SESSION_KEY = 'glue_session_user';
let currentUser = null;
let saveTimer = null;

function getUsers() {
    const raw = localStorage.getItem(USERS_KEY);
    if (!raw) {
        // Initialize with default admin
        const defaultUsers = { 'admin': { password: 'admin123', role: 'admin', createdAt: Date.now() } };
        localStorage.setItem(USERS_KEY, JSON.stringify(defaultUsers));
        return defaultUsers;
    }
    try { return JSON.parse(raw); } catch(e) { return {}; }
}

function saveUsers(users) {
    localStorage.setItem(USERS_KEY, JSON.stringify(users));
}

function getSession() {
    return sessionStorage.getItem(SESSION_KEY) || localStorage.getItem(SESSION_KEY);
}

function setSession(username, remember) {
    if (remember) {
        localStorage.setItem(SESSION_KEY, username);
    } else {
        sessionStorage.setItem(SESSION_KEY, username);
    }
}

function clearSession() {
    sessionStorage.removeItem(SESSION_KEY);
    localStorage.removeItem(SESSION_KEY);
}

function showLogin() {
    document.getElementById('loginForm').style.display = 'block';
    document.getElementById('registerForm').style.display = 'none';
    document.getElementById('loginError').style.display = 'none';
    document.getElementById('loginUser').focus();
}

function showRegister() {
    document.getElementById('loginForm').style.display = 'none';
    document.getElementById('registerForm').style.display = 'block';
    document.getElementById('loginError').style.display = 'none';
    document.getElementById('regUser').focus();
}

function doLogin() {
    const username = document.getElementById('loginUser').value.trim();
    const password = document.getElementById('loginPass').value;
    const errEl = document.getElementById('loginError');

    if (!username || !password) {
        errEl.textContent = '请输入用户名和密码';
        errEl.style.display = 'block';
        return;
    }

    const users = getUsers();
    if (!users[username] || users[username].password !== password) {
        errEl.textContent = '用户名或密码错误';
        errEl.style.display = 'block';
        return;
    }

    currentUser = username;
    setSession(username, true);
    enterSystem();
}

function doRegister() {
    const username = document.getElementById('regUser').value.trim();
    const password = document.getElementById('regPass').value;
    const password2 = document.getElementById('regPass2').value;
    const errEl = document.getElementById('loginError');

    if (!username || !password) {
        errEl.textContent = '请输入用户名和密码';
        errEl.style.display = 'block';
        return;
    }
    if (username.length < 2) {
        errEl.textContent = '用户名至少2个字符';
        errEl.style.display = 'block';
        return;
    }
    if (password.length < 4) {
        errEl.textContent = '密码至少4个字符';
        errEl.style.display = 'block';
        return;
    }
    if (password !== password2) {
        errEl.textContent = '两次输入的密码不一致';
        errEl.style.display = 'block';
        return;
    }

    const users = getUsers();
    if (users[username]) {
        errEl.textContent = '用户名已存在';
        errEl.style.display = 'block';
        return;
    }

    users[username] = { password: password, role: 'user', createdAt: Date.now() };
    saveUsers(users);

    currentUser = username;
    setSession(username, true);
    enterSystem();
}

function doLogout() {
    if (!confirm('确定要退出登录吗？')) return;
    clearSession();
    currentUser = null;
    document.getElementById('loginOverlay').style.display = 'flex';
    document.getElementById('loginUser').value = '';
    document.getElementById('loginPass').value = '';
    showLogin();
}

function enterSystem() {
    document.getElementById('loginOverlay').style.display = 'none';
    updateUserBadge();
    init();
}

function updateUserBadge() {
    const badge = document.getElementById('userBadge');
    if (currentUser) {
        const users = getUsers();
        const role = users[currentUser] ? users[currentUser].role : 'user';
        const initial = currentUser.charAt(0).toUpperCase();
        badge.innerHTML = '<span class="avatar">' + escHtml(initial) + '</span>' + escHtml(currentUser) + (role === 'admin' ? ' · 管理员' : '');
    }
}

function openUserMgmt() {
    const users = getUsers();
    const container = document.getElementById('userListContainer');
    let html = '<table style="width:100%;"><thead><tr><th>用户名</th><th>角色</th><th>注册时间</th><th>操作</th></tr></thead><tbody>';
    Object.entries(users).forEach(([name, info]) => {
        const date = new Date(info.createdAt).toLocaleString('zh-CN');
        const canDelete = name !== 'admin' && name !== currentUser;
        html += '<tr><td class="fw-bold">' + escHtml(name) + (name === currentUser ? ' (当前)' : '') + '</td>'
            + '<td>' + (info.role === 'admin' ? '管理员' : '普通用户') + '</td>'
            + '<td style="font-size:12px;">' + date + '</td>'
            + '<td>' + (canDelete ? '<button class="btn btn-danger btn-sm" onclick="deleteUser(\'' + escAttr(name) + '\')">删除</button>' : '-') + '</td></tr>';
    });
    html += '</tbody></table>';
    html += '<p style="font-size:12px;color:var(--gray-500);margin-top:12px;">※ 管理员账号和当前登录账号不可删除</p>';
    container.innerHTML = html;
    document.getElementById('userMgmtModal').style.display = 'flex';
}

function closeUserMgmt() {
    document.getElementById('userMgmtModal').style.display = 'none';
}

function deleteUser(name) {
    if (!confirm('确定删除用户 "' + name + '" 吗？')) return;
    const users = getUsers();
    delete users[name];
    saveUsers(users);
    openUserMgmt();
    showToast('已删除用户：' + name);
}

// ==================== DATA PERSISTENCE ====================
function saveData() {
    const status = document.getElementById('saveStatus');
    if (status) { status.textContent = '💾 保存中...'; status.className = 'save-status saving'; }

    const data = {
        models: models,
        modelIdCounter: modelIdCounter,
        inventory: inventory,
        savedAt: Date.now(),
        savedBy: currentUser
    };
    try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
        if (status) { status.textContent = '✓ 已保存'; status.className = 'save-status saved'; }
    } catch(e) {
        if (status) { status.textContent = '⚠ 保存失败'; status.className = 'save-status'; }
        showToast('数据保存失败：' + e.message);
    }
}

function saveDataDebounced() {
    if (saveTimer) clearTimeout(saveTimer);
    saveTimer = setTimeout(saveData, 500);
}

function loadData() {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return false;
    try {
        const data = JSON.parse(raw);
        models = data.models || [];
        modelIdCounter = data.modelIdCounter || 0;
        inventory = data.inventory || {};
        return true;
    } catch(e) {
        console.error('Load data error:', e);
        return false;
    }
}

function hasSavedData() {
    return !!localStorage.getItem(STORAGE_KEY);
}

function resetData() {
    if (!confirm('确定要重置所有数据到初始数据库状态吗？\n\n此操作将清除所有已编辑的机型、产量和库存数据，不可恢复！')) return;
    localStorage.removeItem(STORAGE_KEY);
    models = [];
    modelIdCounter = 0;
    inventory = {};
    init();
    showToast('数据已重置到初始状态');
}

// ==================== DATA ====================
let models = [];
let modelIdCounter = 0;
let inventory = {};
let chartInstance = null;
let currentMonth = '';

// ==================== MONTH HELPERS ====================
function getThisMonthStr() {
    const d = new Date();
    return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
}
function getPrevMonthStr(monthStr) {
    const [y, m] = monthStr.split('-').map(Number);
    const d = new Date(y, m - 2, 1);
    return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
}
function getNextMonthStr(monthStr) {
    const [y, m] = monthStr.split('-').map(Number);
    const d = new Date(y, m, 1);
    return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
}
function getMonthQty(m) { return (m.qtyMap && m.qtyMap[currentMonth]) || 0; }
function setMonthQty(m, qty) { if (!m.qtyMap) m.qtyMap = {}; m.qtyMap[currentMonth] = qty; }
function getMonthStock(inv) { return (inv.stockMap && inv.stockMap[currentMonth]) || 0; }
function setMonthStock(inv, stock) { if (!inv.stockMap) inv.stockMap = {}; inv.stockMap[currentMonth] = stock; }
function formatMonthDisplay(ms) {
    const [y, m] = ms.split('-');
    return y + '年' + parseInt(m) + '月';
}

function changeMonth(delta) {
    const newMonth = delta > 0 ? getNextMonthStr(currentMonth) : getPrevMonthStr(currentMonth);
    setCurrentMonth(newMonth);
}
function onMonthChange() {
    const val = document.getElementById('monthPicker').value;
    if (val) setCurrentMonth(val);
}
function setCurrentMonth(ms) {
    currentMonth = ms;
    document.getElementById('monthPicker').value = ms;
    document.getElementById('monthDisplay').textContent = formatMonthDisplay(ms);
    refreshAll();
    updateMonthBadge();
}
function gotoThisMonth() { setCurrentMonth(getThisMonthStr()); }
function updateMonthBadge() {
    let hasData = false;
    models.forEach(m => { if (getMonthQty(m) > 0) hasData = true; });
    if (!hasData) {
        Object.values(inventory).forEach(inv => { if (getMonthStock(inv) > 0) hasData = true; });
    }
    const badge = document.getElementById('monthDataBadge');
    badge.textContent = hasData ? formatMonthDisplay(currentMonth) + ' 已有数据' : formatMonthDisplay(currentMonth) + ' 暂无数据';
    badge.style.background = hasData ? 'var(--green-light)' : 'var(--gray-100)';
    badge.style.color = hasData ? '#065f46' : 'var(--gray-500)';
}
function copyFromPrevMonth() {
    const prevMonth = getPrevMonthStr(currentMonth);
    let copied = 0;
    models.forEach(m => {
        const prevQty = (m.qtyMap && m.qtyMap[prevMonth]) || 0;
        if (prevQty > 0) { setMonthQty(m, prevQty); copied++; }
    });
    Object.values(inventory).forEach(inv => {
        const prevStock = (inv.stockMap && inv.stockMap[prevMonth]) || 0;
        setMonthStock(inv, prevStock);
    });
    refreshAll();
    showToast(copied > 0 ? '已从' + formatMonthDisplay(prevMonth) + '复制 ' + copied + ' 个机型产量及库存' : '上月无数据可复制');
}

// ==================== MODULE SWITCH ====================
function switchModule(n) {
    document.querySelectorAll('.module-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.module-content').forEach(c => c.classList.remove('active'));
    document.getElementById('tab' + n).classList.add('active');
    document.getElementById('module' + n).classList.add('active');
    if (n === 3 && chartInstance) chartInstance.resize();
}

// ==================== INIT ====================
function init() {
    // Check login
    if (!currentUser) {
        const sessionUser = getSession();
        if (sessionUser) {
            const users = getUsers();
            if (users[sessionUser]) {
                currentUser = sessionUser;
                updateUserBadge();
            }
        }
        if (!currentUser) {
            document.getElementById('loginOverlay').style.display = 'flex';
            showLogin();
            return;
        }
    }
    document.getElementById('loginOverlay').style.display = 'none';

    currentMonth = getThisMonthStr();
    document.getElementById('monthPicker').value = currentMonth;
    document.getElementById('monthDisplay').textContent = formatMonthDisplay(currentMonth);

    // Try to load saved data from localStorage
    if (loadData() && models.length > 0) {
        renderGlueCatalog();
        refreshAll();
        updateMonthBadge();
        showToast('已加载保存的数据：' + models.length + '个机型 · ' + Object.keys(inventory).length + '条库存');
        return;
    }

    // No saved data, load from database
    if (typeof GLUE_DATABASE === 'undefined') {
        showToast('数据库加载失败，使用示例数据');
        initSampleData();
        refreshAll();
        updateMonthBadge();
        return;
    }

    // Load BOM models from database
    Object.entries(GLUE_DATABASE.bomModels).forEach(([modelName, data]) => {
        addModelWithData(modelName, data.positions);
    });

    // Load production plan as default monthly qty (case-insensitive match)
    const prodPlanLower = {};
    Object.entries(GLUE_DATABASE.productionPlan).forEach(([k, v]) => { prodPlanLower[k.toLowerCase()] = v; });
    models.forEach(m => {
        const qty = prodPlanLower[m.name.toLowerCase()] || 0;
        if (qty > 0) setMonthQty(m, qty);
    });

    // Load inventory from database
    Object.entries(GLUE_DATABASE.inventory).forEach(([key, inv]) => {
        inventory[key] = {
            glueModel: inv.glueModel,
            gluePartNo: inv.gluePartNo,
            glueDesc: inv.glueDesc,
            containerSize: inv.containerSize,
            stockMap: {},
            productionDate: inv.productionDate || '',
            expiryDate: inv.expiryDate || '',
            shelfLife: inv.shelfLife || 0
        };
        if (inv.stock > 0) setMonthStock(inventory[key], inv.stock);
    });

    renderGlueCatalog();
    refreshAll();
    updateMonthBadge();
    saveData();
    showToast('数据库已加载：' + models.length + '个机型 · ' + Object.keys(inventory).length + '条库存 · ' + (GLUE_DATABASE.glueCatalog ? GLUE_DATABASE.glueCatalog.length : 0) + '种胶水');
}

function initSampleData() {
    addModelWithData('A154', [
        { name: '前腔装喇叭打胶', glueModel: 'AP1536', gluePartNo: 'M.301.01.00062', glueDesc: '硅胶|阿普邦AP1536|55g/支|白色|ROHS,REACH', perUnitUsage: 0.001091, containerSize: 55 },
        { name: '主板点胶装咪套待干', glueModel: 'AP1808B', gluePartNo: 'M.301.01.00067', glueDesc: '硅胶|阿普邦AP1808B|55g/支|黑色|ROHS,REACH', perUnitUsage: 0.000727, containerSize: 55 }
    ]);
    setMonthQty(models[0], 3000);
}

function addModelWithData(name, positions) {
    modelIdCounter++;
    const m = { id: modelIdCounter, name, qtyMap: {}, positions: positions.map((p, i) => ({ id: modelIdCounter * 1000 + i, ...p })) };
    models.push(m);
    positions.forEach(p => {
        const key = p.glueModel + '|' + p.gluePartNo;
        if (!inventory[key]) {
            inventory[key] = { glueModel: p.glueModel, gluePartNo: p.gluePartNo, glueDesc: p.glueDesc, containerSize: p.containerSize, stockMap: {} };
        }
    });
}

function refreshAll() {
    renderProduction();
    renderBOM();
    renderInventory();
    calculate();
    updateKPIs();
    updateMonthBadge();
    saveDataDebounced();
}

// ==================== MODULE 1: PRODUCTION ====================
function getAllDatabaseModels() {
    if (typeof GLUE_DATABASE === 'undefined') return [];
    return Object.keys(GLUE_DATABASE.bomModels).sort();
}

function searchModels(query) {
    const resultsDiv = document.getElementById('modelSearchResults');
    query = (query || '').toLowerCase().trim();
    if (!query) { resultsDiv.style.display = 'none'; return; }

    const allModels = getAllDatabaseModels();
    const existingNames = new Set(models.map(m => m.name.toLowerCase()));
    const matched = allModels.filter(name => name.toLowerCase().includes(query) && !existingNames.has(name.toLowerCase()));
    const alreadyAdded = allModels.filter(name => name.toLowerCase().includes(query) && existingNames.has(name.toLowerCase()));

    if (matched.length === 0 && alreadyAdded.length === 0) {
        resultsDiv.innerHTML = '<div class="search-result-item" style="cursor:default;color:var(--gray-500);">未找到匹配机型</div>';
        resultsDiv.style.display = 'block';
        return;
    }

    let html = '';
    matched.forEach(name => {
        const posCount = GLUE_DATABASE.bomModels[name].positions.length;
        html += `<div class="search-result-item" onclick="addModelFromSearch('${escAttr(name)}')">
            <span><strong>${escHtml(name)}</strong></span>
            <span class="model-badge">${posCount}个BOM位置 · 点击添加</span>
        </div>`;
    });
    alreadyAdded.forEach(name => {
        html += `<div class="search-result-item added">
            <span>${escHtml(name)}</span>
            <span class="model-badge">已添加 ✓</span>
        </div>`;
    });
    resultsDiv.innerHTML = html;
    resultsDiv.style.display = 'block';
}

document.addEventListener('click', function(e) {
    const container = e.target.closest('.search-container');
    if (!container) {
        const resultsDiv = document.getElementById('modelSearchResults');
        if (resultsDiv) resultsDiv.style.display = 'none';
    }
});

function addModelFromSearch(name) {
    if (models.find(m => m.name === name)) {
        showToast('机型 ' + name + ' 已存在');
        return;
    }
    const dbData = (typeof GLUE_DATABASE !== 'undefined' && GLUE_DATABASE.bomModels[name]) ? GLUE_DATABASE.bomModels[name] : null;
    if (dbData) {
        addModelWithData(name, dbData.positions);
    } else {
        modelIdCounter++;
        models.push({ id: modelIdCounter, name, qtyMap: {}, positions: [] });
    }
    document.getElementById('modelSearchInput').value = '';
    document.getElementById('modelSearchResults').style.display = 'none';
    refreshAll();
    showToast('已添加机型：' + name);
}

function addManualModel() {
    modelIdCounter++;
    const name = '新机型' + modelIdCounter;
    models.push({ id: modelIdCounter, name, qtyMap: {}, positions: [] });
    refreshAll();
    showToast('已添加空白机型，请编辑名称');
}

function renderProduction() {
    const tbody = document.querySelector('#prodTable tbody');
    const monthLabel = formatMonthDisplay(currentMonth);
    const lbl = document.getElementById('prodMonthLabel');
    if (lbl) lbl.textContent = monthLabel;
    const lblKpi = document.getElementById('kpiProdMonthLabel');
    if (lblKpi) lblKpi.textContent = monthLabel;

    if (models.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--gray-500);padding:24px;">暂无机型，请在上方搜索添加或批量导入</td></tr>';
        return;
    }

    tbody.innerHTML = models.map((m, i) => {
        const qty = getMonthQty(m);
        const posCount = m.positions.length;
        const glueSet = new Set();
        m.positions.forEach(p => { if (p.glueModel) glueSet.add(p.glueModel); });
        return `<tr>
            <td style="text-align:center;color:var(--gray-500);">${i + 1}</td>
            <td><input type="text" class="mid" value="${escHtml(m.name)}" onchange="updateModelName(${m.id}, this.value)" style="font-weight:600;"></td>
            <td><input type="number" class="model-qty-input" value="${qty}" min="0" onchange="updateModelQty(${m.id}, this.value)" style="${qty > 0 ? 'border-color:var(--green);background:var(--green-light);' : ''}"></td>
            <td style="text-align:center;">${posCount}</td>
            <td style="text-align:center;">${glueSet.size}</td>
            <td><button class="btn btn-danger btn-sm" onclick="deleteModel(${m.id})">删除</button></td>
        </tr>`;
    }).join('');
}

function updateModelQty(id, value) {
    const m = models.find(m => m.id === id);
    if (m) { setMonthQty(m, parseInt(value) || 0); calculate(); updateKPIs(); updateMonthBadge(); renderProduction(); saveDataDebounced(); }
}

// ==================== KPI ====================
function updateKPIs() {
    const monthLabel = formatMonthDisplay(currentMonth);

    // --- Module 1 KPIs ---
    document.getElementById('kpiProdModels').textContent = models.length;
    const scheduledCount = models.filter(m => getMonthQty(m) > 0).length;
    document.getElementById('kpiProdScheduled').textContent = scheduledCount;
    let totalProd = 0;
    models.forEach(m => { totalProd += getMonthQty(m); });
    document.getElementById('kpiProdTotal').innerHTML = totalProd + '<span class="kpi-unit">台</span>';

    // --- Module 2 KPIs ---
    document.getElementById('kpiModels').textContent = models.length;
    const glueKeys = new Set();
    models.forEach(m => m.positions.forEach(p => glueKeys.add(p.glueModel + '|' + p.gluePartNo)));
    document.getElementById('kpiGlueTypes').textContent = glueKeys.size;

    const demandMap = computeDemand();
    let totalDemand = 0;
    Object.values(demandMap).forEach(d => { totalDemand += d.ceiledDemand || 0; });
    document.getElementById('kpiTotalDemand').innerHTML = totalDemand + '<span class="kpi-unit">支/桶</span>';
    const lbl1 = document.getElementById('kpiDemandMonthLabel');
    if (lbl1) lbl1.textContent = monthLabel;

    // --- Module 3 KPIs ---
    document.getElementById('kpiInvTypes').textContent = Object.keys(inventory).length;
    let needBuyCount = 0, totalPurchase = 0;
    Object.entries(demandMap).forEach(([key, d]) => {
        const inv = inventory[key];
        const stock = inv ? getMonthStock(inv) : 0;
        const purchase = Math.max(0, (d.ceiledDemand || 0) - stock);
        if (purchase > 0) { needBuyCount++; totalPurchase += purchase; }
    });
    document.getElementById('kpiNeedBuy').textContent = needBuyCount;
    document.getElementById('kpiTotalPurchase').innerHTML = totalPurchase + '<span class="kpi-unit">支/桶</span>';
    const lbl2 = document.getElementById('kpiPurchaseMonthLabel');
    if (lbl2) lbl2.textContent = monthLabel;
}

// ==================== MODULE 2: BOM ====================
function addModel() {
    modelIdCounter++;
    models.push({ id: modelIdCounter, name: '新机型' + modelIdCounter, qtyMap: {}, positions: [] });
    refreshAll();
}

function deleteModel(id) {
    if (!confirm('确定删除该机型及其所有BOM配置？')) return;
    models = models.filter(m => m.id !== id);
    refreshAll();
}

function updateModelName(id, value) {
    const m = models.find(m => m.id === id);
    if (m) m.name = value || '未命名';
    refreshAll();
}

function addPosition(modelId) {
    const m = models.find(m => m.id === modelId);
    if (!m) return;
    const maxId = m.positions.reduce((mx, p) => Math.max(mx, p.id), 0);
    m.positions.push({ id: maxId + 1, name: '', glueModel: '', gluePartNo: '', glueDesc: '', perUnitUsage: 0, containerSize: 0 });
    refreshAll();
}

function deletePosition(modelId, posId) {
    const m = models.find(m => m.id === modelId);
    if (!m) return;
    m.positions = m.positions.filter(p => p.id !== posId);
    refreshAll();
}

function updatePosition(modelId, posId, field, value) {
    const m = models.find(m => m.id === modelId);
    if (!m) return;
    const p = m.positions.find(p => p.id === posId);
    if (!p) return;
    if (field === 'perUnitUsage' || field === 'containerSize') {
        p[field] = parseFloat(value) || 0;
    } else {
        p[field] = value;
    }
    if (field === 'glueModel' || field === 'gluePartNo' || field === 'glueDesc' || field === 'containerSize') {
        autoSyncInventoryFromPosition(p);
    }
    calculate();
    saveDataDebounced();
}

function autoSyncInventoryFromPosition(p) {
    if (!p.glueModel || !p.gluePartNo) return;
    const key = p.glueModel + '|' + p.gluePartNo;
    if (!inventory[key]) {
        inventory[key] = { glueModel: p.glueModel, gluePartNo: p.gluePartNo, glueDesc: p.glueDesc, containerSize: p.containerSize, stockMap: {} };
    } else {
        if (!inventory[key].glueDesc) inventory[key].glueDesc = p.glueDesc;
        if (!inventory[key].containerSize) inventory[key].containerSize = p.containerSize;
    }
}

function renderBOM() {
    const container = document.getElementById('bomContainer');
    const searchInput = document.getElementById('bomSearchInput');
    const searchQuery = searchInput ? (searchInput.value || '').toLowerCase().trim() : '';
    const infoEl = document.getElementById('bomSearchInfo');

    if (models.length === 0) {
        container.innerHTML = '<div class="empty-state"><div style="font-size:32px;">🧴</div><p>暂无机型，请先在模块一添加机型</p></div>';
        if (infoEl) infoEl.textContent = '※ 机型列表来自模块一，月产量请在模块一中编辑';
        return;
    }

    // Filter models by search query
    let filteredModels = models;
    if (searchQuery) {
        filteredModels = models.filter(m => m.name.toLowerCase().includes(searchQuery));
        if (infoEl) infoEl.textContent = '🔍 搜索"' + searchQuery + '"，找到 ' + filteredModels.length + ' 个机型（共 ' + models.length + ' 个）';
    } else {
        if (infoEl) infoEl.textContent = '※ 机型列表来自模块一，月产量请在模块一中编辑（共 ' + models.length + ' 个机型）';
    }

    if (filteredModels.length === 0) {
        container.innerHTML = '<div class="empty-state"><div style="font-size:32px;">🔍</div><p>未找到匹配的机型</p></div>';
        return;
    }

    container.innerHTML = filteredModels.map(m => `
        <div class="model-card" id="bomModel${m.id}">
            <div class="model-card-header">
                <div class="model-info">
                    <span class="model-name">📱 ${escHtml(m.name)}</span>
                    <span style="font-size:12px;color:var(--gray-500);">${m.positions.length}个位置</span>
                    ${m.positions.length > 0 ? '<span class="copy-bom-badge" onclick="copyBOM(' + m.id + ')" title="复制此机型BOM配置到新机型">📋 复制BOM</span>' : ''}
                </div>
                <div class="model-actions">
                    <button class="btn btn-outline btn-sm" onclick="addPosition(${m.id})">+ 添加位置</button>
                    <button class="btn btn-outline btn-sm" onclick="copyBOM(${m.id})" style="font-size:11px;" title="复制所有BOM配置到新机型">📋 复制BOM</button>
                    <button class="btn btn-danger btn-sm" onclick="deleteModel(${m.id})">删除机型</button>
                </div>
            </div>
            <div class="model-card-body">
                ${m.positions.length === 0 ? '<div style="font-size:12px;color:var(--gray-500);padding:8px 0;">暂无位置配置，点击"添加位置"</div>' : `
                <div class="table-wrapper"><table>
                    <thead><tr>
                        <th style="width:160px;">打胶位置</th>
                        <th>胶水型号</th>
                        <th>胶水料号</th>
                        <th>胶水描述</th>
                        <th style="width:110px;">单套用量(支/桶)</th>
                        <th style="width:90px;">规格容量(g)</th>
                        <th style="width:60px;">操作</th>
                    </tr></thead>
                    <tbody>
                        ${m.positions.map(p => `
                        <tr>
                            <td><input type="text" class="wide" value="${escHtml(p.name)}" onchange="updatePosition(${m.id},${p.id},'name',this.value)" placeholder="位置名称"></td>
                            <td><input type="text" class="mid" value="${escHtml(p.glueModel)}" onchange="updatePosition(${m.id},${p.id},'glueModel',this.value)" placeholder="胶水型号"></td>
                            <td><input type="text" class="mid" value="${escHtml(p.gluePartNo)}" onchange="updatePosition(${m.id},${p.id},'gluePartNo',this.value)" placeholder="料号"></td>
                            <td><input type="text" class="wide" value="${escHtml(p.glueDesc)}" onchange="updatePosition(${m.id},${p.id},'glueDesc',this.value)" placeholder="描述"></td>
                            <td><input type="number" class="tight" value="${p.perUnitUsage}" min="0" step="0.000001" onchange="updatePosition(${m.id},${p.id},'perUnitUsage',this.value)"></td>
                            <td><input type="number" class="tight" value="${p.containerSize}" min="0" step="0.1" onchange="updatePosition(${m.id},${p.id},'containerSize',this.value)"></td>
                            <td><button class="btn btn-outline btn-sm" onclick="deletePosition(${m.id},${p.id})">✕</button></td>
                        </tr>
                        `).join('')}
                    </tbody>
                </table></div>
                `}
            </div>
        </div>
    `).join('');
}

// ==================== COPY BOM ====================
function copyBOM(sourceId) {
    const src = models.find(m => m.id === sourceId);
    if (!src) return;
    if (src.positions.length === 0) {
        showToast('该机型无需复制的位置配置');
        return;
    }

    // Show copy modal
    const overlay = document.getElementById('copyBomOverlay');
    const sourceInfo = document.getElementById('copyBomSourceInfo');
    const targetSelect = document.getElementById('copyBomTargetSelect');
    const newNameInput = document.getElementById('copyBomNewName');

    if (!overlay) {
        // Simple prompt-based copy
        const newName = prompt('请输入新机型名称（留空则自动生成）：', src.name + '-副本');
        if (newName === null) return;
        doCopyBOM(sourceId, null, newName || (src.name + '-副本'));
        return;
    }

    sourceInfo.textContent = src.name + '（' + src.positions.length + '个位置）';

    // Populate existing target models
    targetSelect.innerHTML = '<option value="">-- 创建新机型（输入名称） --</option>';
    models.forEach(m => {
        if (m.id !== sourceId) {
            targetSelect.innerHTML += '<option value="' + m.id + '">' + escHtml(m.name) + '（' + m.positions.length + '个位置）</option>';
        }
    });

    newNameInput.value = src.name + '-副本';
    newNameInput.style.display = 'block';
    overlay.style.display = 'flex';

    // Store sourceId for confirm
    overlay._copySourceId = sourceId;
}

function confirmCopyBOM() {
    const overlay = document.getElementById('copyBomOverlay');
    const sourceId = overlay._copySourceId;
    const targetSelect = document.getElementById('copyBomTargetSelect');
    const newNameInput = document.getElementById('copyBomNewName');
    const targetId = targetSelect.value ? parseInt(targetSelect.value) : null;

    if (!targetId) {
        // Create new model
        const newName = (newNameInput.value || '').trim();
        if (!newName) {
            showToast('请输入新机型名称');
            return;
        }
        doCopyBOM(sourceId, null, newName);
    } else {
        // Copy to existing - confirm overwrite
        const target = models.find(m => m.id === targetId);
        if (!target) return;
        if (target.positions.length > 0) {
            if (!confirm('目标机型"' + target.name + '"已有 ' + target.positions.length + ' 个位置配置，复制将覆盖现有配置。确定继续？')) return;
        }
        doCopyBOM(sourceId, targetId, null);
    }

    overlay.style.display = 'none';
}

function cancelCopyBOM() {
    const overlay = document.getElementById('copyBomOverlay');
    overlay.style.display = 'none';
}

function onCopyTargetChange() {
    const targetSelect = document.getElementById('copyBomTargetSelect');
    const newNameInput = document.getElementById('copyBomNewName');
    if (targetSelect.value) {
        newNameInput.style.display = 'none';
    } else {
        newNameInput.style.display = 'block';
    }
}

function doCopyBOM(sourceId, targetId, newName) {
    const src = models.find(m => m.id === sourceId);
    if (!src) return;

    if (targetId) {
        // Copy to existing model
        const target = models.find(m => m.id === targetId);
        if (!target) return;
        target.positions = src.positions.map(p => ({...p, id: Date.now() + Math.random()}));
        refreshAll();
        showToast('已将"' + src.name + '"的BOM复制到"' + target.name + '"');
    } else {
        // Create new model
        modelIdCounter++;
        const newModel = {
            id: modelIdCounter,
            name: newName,
            qtyMap: {},
            positions: src.positions.map(p => ({...p, id: Date.now() + Math.random()}))
        };
        models.push(newModel);
        refreshAll();
        showToast('已创建新机型"' + newName + '"，BOM来自"' + src.name + '"');
    }
}

// ==================== MODULE 2: GLUE CATALOG ====================
function toggleCatalog() {
    const container = document.getElementById('glueCatalogContainer');
    const btn = document.getElementById('catalogToggleBtn');
    if (container.style.display === 'none') {
        container.style.display = 'block';
        btn.textContent = '▲ 收起';
        renderGlueCatalog();
    } else {
        container.style.display = 'none';
        btn.textContent = '▼ 展开';
    }
}

function renderGlueCatalog() {
    const tbody = document.querySelector('#glueCatalogTable tbody');
    if (!tbody) return;
    const search = (document.getElementById('catalogSearch') ? document.getElementById('catalogSearch').value : '').toLowerCase().trim();
    let catalog = (typeof GLUE_DATABASE !== 'undefined' && GLUE_DATABASE.glueCatalog) ? GLUE_DATABASE.glueCatalog : [];
    let filtered = catalog;
    if (search) {
        filtered = catalog.filter(g =>
            (g.name || '').toLowerCase().includes(search) ||
            (g.partNo || '').toLowerCase().includes(search) ||
            (g.spec || '').toLowerCase().includes(search) ||
            (g.type || '').toLowerCase().includes(search)
        );
    }
    const info = document.getElementById('catalogInfo');
    if (info) info.textContent = '共 ' + catalog.length + ' 种胶水' + (search ? '，筛选出 ' + filtered.length + ' 条' : '');
    if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--gray-500);padding:16px;">未找到匹配的胶水</td></tr>';
        return;
    }
    tbody.innerHTML = filtered.map((g, i) => {
        return `<tr>
            <td style="text-align:center;color:var(--gray-500);">${i + 1}</td>
            <td style="font-weight:600;color:var(--primary-dark);">${escHtml(g.name)}</td>
            <td style="font-family:monospace;">${escHtml(g.partNo)}</td>
            <td style="font-size:12px;">${escHtml(g.type)}</td>
            <td style="font-size:12px;">${escHtml(g.spec)}</td>
            <td style="text-align:center;">${g.containerSize > 0 ? g.containerSize + ' ML' : '-'}</td>
        </tr>`;
    }).join('');
}

// ==================== MODULE 3: INVENTORY ====================
function renderInventory() {
    const tbody = document.querySelector('#inventoryTable tbody');
    const keys = Object.keys(inventory);
    if (keys.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--gray-500);padding:24px;">暂无库存数据，请点击「+ 新增胶水」手动添加或导入</td></tr>';
        return;
    }
    const today = new Date();
    tbody.innerHTML = keys.map(key => {
        const inv = inventory[key];
        let expiryHtml = '-';
        if (inv.expiryDate && inv.expiryDate !== '1900-12-25 00:00:00') {
            const expDate = new Date(inv.expiryDate);
            const daysLeft = Math.ceil((expDate - today) / (1000 * 60 * 60 * 24));
            let color = 'var(--green)';
            let bg = '';
            if (daysLeft < 0) { color = 'var(--red)'; bg = 'background:var(--red-light);'; }
            else if (daysLeft <= 10) { color = 'var(--red)'; bg = 'background:var(--red-light);'; }
            else if (daysLeft <= 30) { color = 'var(--orange)'; bg = 'background:var(--orange-light);'; }
            const dateStr = inv.expiryDate.split(' ')[0];
            expiryHtml = `<div style="${bg}padding:3px 8px;border-radius:4px;font-size:12px;color:${color};font-weight:600;">${dateStr}<br><span style="font-size:10px;font-weight:400;">${daysLeft < 0 ? '已过期' + Math.abs(daysLeft) + '天' : '剩' + daysLeft + '天'}</span></div>`;
        }
        return `<tr>
            <td><input type="text" class="mid" value="${escHtml(inv.glueModel)}" onchange="updateInventoryField('${escAttr(key)}','glueModel',this.value)" placeholder="输入胶水型号"></td>
            <td><input type="text" class="mid" value="${escHtml(inv.gluePartNo)}" onchange="updateInventoryField('${escAttr(key)}','gluePartNo',this.value)" placeholder="输入料号"></td>
            <td><input type="text" class="wide" value="${escHtml(inv.glueDesc)}" onchange="updateInventoryField('${escAttr(key)}','glueDesc',this.value)" placeholder="输入描述"></td>
            <td><input type="number" class="tight" value="${inv.containerSize || 0}" min="0" step="0.1" onchange="updateInventoryField('${escAttr(key)}','containerSize',this.value)" style="width:70px;"></td>
            <td><input type="number" class="tight" value="${getMonthStock(inv)}" min="0" step="1"
                onchange="updateInventory('${escAttr(key)}', this.value)"></td>
            <td>${expiryHtml}</td>
            <td><button class="btn btn-outline btn-sm" onclick="deleteInventory('${escAttr(key)}')">删除</button></td>
        </tr>`;
    }).join('');
}

function addInventoryRow() {
    let idx = 1;
    let key = '新胶水|NEW-' + Date.now();
    while (inventory[key]) { key = '新胶水|NEW-' + Date.now() + '-' + idx++; }
    inventory[key] = { glueModel: '', gluePartNo: '', glueDesc: '', containerSize: 0, stockMap: {}, productionDate: '', expiryDate: '', shelfLife: 0 };
    renderInventory();
    setTimeout(() => {
        const rows = document.querySelectorAll('#inventoryTable tbody tr');
        if (rows.length > 0) {
            const lastRow = rows[rows.length - 1];
            const firstInput = lastRow.querySelector('input');
            if (firstInput) firstInput.focus();
        }
    }, 50);
}

function updateInventoryField(oldKey, field, value) {
    const inv = inventory[oldKey];
    if (!inv) return;
    if (field === 'containerSize') {
        inv[field] = parseFloat(value) || 0;
    } else {
        inv[field] = value;
    }
    if (field === 'glueModel' || field === 'gluePartNo') {
        const newKey = inv.glueModel + '|' + inv.gluePartNo;
        if (newKey !== oldKey) {
            if (inventory[newKey]) {
                const existingStock = getMonthStock(inventory[newKey]);
                const currentStock = getMonthStock(inv);
                setMonthStock(inventory[newKey], Math.max(existingStock, currentStock));
                if (!inventory[newKey].glueDesc && inv.glueDesc) inventory[newKey].glueDesc = inv.glueDesc;
                if (!inventory[newKey].containerSize && inv.containerSize) inventory[newKey].containerSize = inv.containerSize;
                delete inventory[oldKey];
                showToast('已合并到现有胶水：' + newKey);
            } else {
                inventory[newKey] = inv;
                delete inventory[oldKey];
            }
        }
    }
    calculate();
    saveDataDebounced();
}

function updateInventory(key, value) {
    if (inventory[key]) setMonthStock(inventory[key], parseInt(value) || 0);
    calculate();
    saveDataDebounced();
}

function deleteInventory(key) {
    delete inventory[key];
    refreshAll();
}

function syncInventoryFromBOM() {
    models.forEach(m => m.positions.forEach(p => {
        if (p.glueModel && p.gluePartNo) {
            const k = p.glueModel + '|' + p.gluePartNo;
            if (!inventory[k]) {
                inventory[k] = { glueModel: p.glueModel, gluePartNo: p.gluePartNo, glueDesc: p.glueDesc, containerSize: p.containerSize, stockMap: {} };
            }
        }
    }));
    refreshAll();
    showToast('已从BOM同步库存项（新胶水初始库存为0）');
}

// ==================== CALCULATE ====================
function computeDemand() {
    const map = {};
    models.forEach(m => {
        const qty = getMonthQty(m);
        m.positions.forEach(p => {
            if (!p.glueModel || !p.gluePartNo) return;
            const demand = qty * p.perUnitUsage;
            const key = p.glueModel + '|' + p.gluePartNo;
            if (!map[key]) map[key] = { glueModel: p.glueModel, gluePartNo: p.gluePartNo, glueDesc: p.glueDesc, containerSize: p.containerSize, totalDemand: 0, details: [] };
            map[key].totalDemand += demand;
            map[key].details.push({ modelName: m.name, posName: p.name, monthlyQty: qty, perUnitUsage: p.perUnitUsage, containerSize: p.containerSize, demand });
        });
    });
    Object.values(map).forEach(d => {
        d.totalDemand = Math.round(d.totalDemand * 100) / 100;
        d.ceiledDemand = d.totalDemand > 0 ? Math.ceil(d.totalDemand) : 0;
        d.details.forEach(x => { x.demand = Math.round(x.demand * 100) / 100; x.ceiledDemand = x.demand > 0 ? Math.ceil(x.demand) : 0; });
    });
    return map;
}

function calculate() {
    const demandMap = computeDemand();
    const monthLabel = formatMonthDisplay(currentMonth);

    const resultLabel = document.getElementById('resultMonthLabel');
    if (resultLabel) resultLabel.textContent = monthLabel;
    const invLabel = document.getElementById('invMonthLabel');
    if (invLabel) invLabel.textContent = monthLabel;

    renderDemandTable(demandMap);

    const tbody = document.querySelector('#resultTable tbody');
    const detailTbody = document.querySelector('#detailTable tbody');

    if (Object.keys(demandMap).length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--gray-500);padding:24px;">请先在模块一/二配置机型产量和BOM数据</td></tr>';
        detailTbody.innerHTML = '';
        updateChart([]);
        updateKPIs();
        renderInventory();
        return;
    }

    tbody.innerHTML = Object.entries(demandMap).map(([key, d]) => {
        const inv = inventory[key];
        const stock = inv ? getMonthStock(inv) : 0;
        const ceiledDemand = d.ceiledDemand || 0;
        const purchaseNeed = Math.max(0, ceiledDemand - stock);
        const rowClass = purchaseNeed > 0 ? '' : 'bg-green-light';
        const status = purchaseNeed > 0
            ? '<span class="text-red fw-bold">需采购</span>'
            : '<span class="text-green fw-bold">库存充足 ✓</span>';
        const demandDisplay = d.totalDemand > 0 && d.totalDemand < ceiledDemand
            ? `${ceiledDemand}<span style="font-size:10px;color:var(--gray-500);"> (精确${d.totalDemand.toFixed(2)})</span>`
            : `${ceiledDemand}`;
        return `<tr class="${rowClass}">
            <td class="fw-bold">${escHtml(d.glueModel)}</td>
            <td>${escHtml(d.gluePartNo)}</td>
            <td style="font-size:12px;">${escHtml(d.glueDesc)}</td>
            <td class="fw-bold">${demandDisplay}</td>
            <td>${stock}</td>
            <td class="fw-bold ${purchaseNeed > 0 ? 'text-red' : 'text-green'}">${purchaseNeed > 0 ? purchaseNeed : '0 ✓'}</td>
            <td>${status}</td>
        </tr>`;
    }).join('');

    const allDetails = [];
    Object.values(demandMap).forEach(d => d.details.forEach(x => { x.glueModel = d.glueModel; x.gluePartNo = d.gluePartNo; allDetails.push(x); }));
    detailTbody.innerHTML = allDetails.map(x => `<tr>
        <td>${escHtml(x.modelName)}</td>
        <td>${x.monthlyQty}</td>
        <td>${escHtml(x.posName)}</td>
        <td>${escHtml(x.glueModel)}</td>
        <td>${escHtml(x.gluePartNo)}</td>
        <td>${x.perUnitUsage}</td>
        <td>${x.containerSize || '-'}</td>
        <td>${x.demand.toFixed(2)}</td>
        <td class="fw-bold">${x.ceiledDemand || 0}</td>
    </tr>`).join('');

    updateChart(demandMap);
    updateKPIs();
    renderInventory();
}

// ==================== DEMAND TABLE ====================
function renderDemandTable(demandMap) {
    const tbody = document.querySelector('#demandTable tbody');
    const label = document.getElementById('demandMonthLabel');
    if (label) label.textContent = formatMonthDisplay(currentMonth);
    if (!demandMap) demandMap = computeDemand();
    if (Object.keys(demandMap).length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--gray-500);padding:24px;">请先配置机型BOM数据及月产量</td></tr>';
        return;
    }
    tbody.innerHTML = Object.entries(demandMap).map(([key, d]) => {
        const involved = d.details.map(x => x.modelName + '/' + x.posName).join('；');
        const demandDisplay = d.totalDemand > 0 && d.totalDemand < d.ceiledDemand
            ? `${d.ceiledDemand}<span style="font-size:10px;color:var(--gray-500);"> (精确${d.totalDemand.toFixed(2)})</span>`
            : `${d.ceiledDemand}`;
        return `<tr>
            <td class="fw-bold">${escHtml(d.glueModel)}</td>
            <td>${escHtml(d.gluePartNo)}</td>
            <td style="font-size:12px;">${escHtml(d.glueDesc)}</td>
            <td>${d.containerSize || '-'} g</td>
            <td class="fw-bold" style="color:var(--primary-dark);">${demandDisplay}</td>
            <td style="font-size:11px;color:var(--gray-500);">${escHtml(involved)}</td>
        </tr>`;
    }).join('');
}

function updateChart(demandMap) {
    if (chartInstance) chartInstance.destroy();
    const ctx = document.getElementById('purchaseChart').getContext('2d');
    const entries = Object.entries(demandMap);
    if (entries.length === 0) { chartInstance = null; return; }
    const labels = entries.map(([k, d]) => d.glueModel + '\n' + d.gluePartNo.substring(0, 8));
    const demandData = entries.map(([k, d]) => d.ceiledDemand || 0);
    const purchaseData = entries.map(([k, d]) => {
        const inv = inventory[k];
        return Math.max(0, (d.ceiledDemand || 0) - (inv ? getMonthStock(inv) : 0));
    });
    chartInstance = new Chart(ctx, {
        type: 'bar',
        data: {
            labels,
            datasets: [
                { label: '月需求量(支/桶)', data: demandData, backgroundColor: '#2563eb', borderRadius: 6 },
                { label: '需采购(支/桶)', data: purchaseData, backgroundColor: '#ef4444', borderRadius: 6 }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { font: { size: 12 } } },
                tooltip: { callbacks: { label: ctx => ctx.dataset.label + ': ' + ctx.raw + ' 支/桶' } }
            },
            scales: {
                y: { beginAtZero: true, title: { display: true, text: '支/桶', font: { size: 12 } } },
                x: { ticks: { font: { size: 10 } } }
            }
        }
    });
}

// ==================== PRODUCTION IMPORT ====================
function openImportProd() {
    document.getElementById('prodImportMonthLabel').textContent = formatMonthDisplay(currentMonth);
    document.getElementById('prodImportModal').classList.add('open');
}
function closeProdImport() { document.getElementById('prodImportModal').classList.remove('open'); document.getElementById('prodImportMsg').innerHTML = ''; document.getElementById('prodFileMsg').innerHTML = ''; }

function fillProdSample() {
    document.getElementById('prodCsvInput').value = 'A154,3000\nB200,5000\nC300,2000';
}

function downloadProdTemplate() {
    const csv = '机型,月产量\nA154,3000\nB200,5000';
    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = '机型产量_导入模板.csv'; a.click();
    showToast('产量模板已下载');
}

function doImportProd() {
    const raw = document.getElementById('prodCsvInput').value.trim();
    const msg = document.getElementById('prodImportMsg');
    msg.innerHTML = '';
    if (!raw) { msg.innerHTML = '<div class="import-result error">请先粘贴产量数据</div>'; return; }
    const lines = raw.split(/\r?\n/).filter(l => l.trim() && !l.startsWith('机型'));
    const errors = [];
    let count = 0;
    lines.forEach((line, idx) => {
        const parts = line.split(',').map(s => s.trim());
        if (parts.length < 2) { errors.push('第'+(idx+1)+'行格式错误'); return; }
        const modelName = parts[0];
        const qty = parseInt(parts[1], 10);
        if (!modelName) { errors.push('第'+(idx+1)+'行机型为空'); return; }
        if (isNaN(qty) || qty < 0) { errors.push('第'+(idx+1)+'行('+modelName+')产量无效'); return; }
        // Find existing model (case-insensitive)
        let m = models.find(x => x.name.toLowerCase() === modelName.toLowerCase());
        if (m) {
            setMonthQty(m, qty);
        } else {
            // Try to find in database and add with BOM
            const dbData = (typeof GLUE_DATABASE !== 'undefined' && GLUE_DATABASE.bomModels[modelName]) ? GLUE_DATABASE.bomModels[modelName] : null;
            if (dbData) {
                addModelWithData(modelName, dbData.positions);
                m = models[models.length - 1];
            } else {
                modelIdCounter++;
                m = { id: modelIdCounter, name: modelName, qtyMap: {}, positions: [] };
                models.push(m);
            }
            setMonthQty(m, qty);
        }
        count++;
    });
    closeProdImport(); refreshAll();
    let info = '产量导入成功，更新 ' + count + ' 个机型';
    if (errors.length) info += '，' + errors.length + ' 行跳过';
    showToast(info);
}

function handleProdFileSelect(ev) { if (ev.target.files[0]) handleProdFile(ev.target.files[0]); }
function handleProdFile(file) {
    const r = new FileReader();
    r.onload = function(ev) {
        document.getElementById('prodCsvInput').value = ev.target.result.trim();
        switchTab('prod-paste', document.querySelector('#prodImportModal .modal-tab'));
        showToast('产量文件已加载，请确认后导入');
    };
    r.readAsText(file, 'UTF-8');
}

function exportProdCSV() {
    let csv = '\uFEFF机型月产量_' + currentMonth + '\n\n';
    csv += '机型,月产量(台),BOM位置数,涉及胶水数\n';
    models.forEach(m => {
        const glueSet = new Set();
        m.positions.forEach(p => { if (p.glueModel) glueSet.add(p.glueModel); });
        csv += `"${m.name}",${getMonthQty(m)},${m.positions.length},${glueSet.size}\n`;
    });
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = '机型产量_' + currentMonth + '.csv';
    a.click();
    showToast(currentMonth + ' 机型产量表已导出');
}

// ==================== BOM IMPORT ====================
const templateBomGlueCsv = 'A154,前腔装喇叭打胶,AP1536,M.301.01.00062,硅胶|阿普邦AP1536|55g/支|白色|ROHS,REACH,0.001091,55\nA154,主板点胶装咪套待干,AP1908B,M.301.01.00067,硅胶|阿普邦AP1908B|55g/支|黑色|ROHS,REACH,0.000727,55';
const templateBOMCSV = '机型,打胶位置,胶水型号,胶水料号,胶水描述,单套用量(支/桶),规格容量(g)\n' + templateBomGlueCsv;

function openImportBOM() {
    document.getElementById('bomImportModal').classList.add('open');
}
function closeBOMImport() { document.getElementById('bomImportModal').classList.remove('open'); document.getElementById('bomImportMsg').innerHTML = ''; document.getElementById('bomFileMsg').innerHTML = ''; }
function fillBomGlueCsv() { document.getElementById('bomGlueCsv').value = templateBomGlueCsv; }
function downloadBOMTemplate() {
    const blob = new Blob(['\uFEFF' + templateBOMCSV], { type: 'text/csv;charset=utf-8;' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'BOM配置_导入模板.csv'; a.click();
    showToast('BOM模板已下载');
}

function doImportBOM() {
    const glueRaw = document.getElementById('bomGlueCsv').value.trim();
    const msg = document.getElementById('bomImportMsg');
    msg.innerHTML = '';
    if (!glueRaw) { msg.innerHTML = '<div class="import-result error">请先填写胶水配置明细</div>'; return; }

    const glueLines = glueRaw.split(/\r?\n/).filter(l => l.trim() && !l.startsWith('机型'));
    const errors = [];
    const modelPosMap = {};

    glueLines.forEach((line, idx) => {
        const parts = line.split(',').map(s => s.trim());
        if (parts.length < 7) { errors.push('第'+(idx+1)+'行字段不足（需7列）'); return; }
        const [modelName, posName, glueModel, gluePartNo, glueDesc, usageStr, containerStr] = parts;
        const usage = parseFloat(usageStr), container = parseFloat(containerStr);
        if (isNaN(usage) || usage < 0) { errors.push('第'+(idx+1)+'行('+modelName+')单套用量无效'); return; }
        if (isNaN(container)) container = 0;
        if (!modelPosMap[modelName]) modelPosMap[modelName] = [];
        modelPosMap[modelName].push({ name: posName, glueModel, gluePartNo, glueDesc, perUnitUsage: usage, containerSize: container });
    });

    if (Object.keys(modelPosMap).length === 0) {
        msg.innerHTML = '<div class="import-result error">未解析到有效数据<br>' + errors.join('<br>') + '</div>'; return;
    }

    // Merge into models - update positions for existing, create new if not exist
    Object.entries(modelPosMap).forEach(([name, positions]) => {
        let m = models.find(x => x.name.toLowerCase() === name.toLowerCase());
        if (m) {
            // Replace positions
            const maxId = m.positions.reduce((mx, p) => Math.max(mx, p.id), 0);
            m.positions = positions.map((p, i) => ({ id: maxId + 1 + i, ...p }));
        } else {
            // Create new model (from database if available, otherwise empty)
            const dbData = (typeof GLUE_DATABASE !== 'undefined' && GLUE_DATABASE.bomModels[name]) ? GLUE_DATABASE.bomModels[name] : null;
            modelIdCounter++;
            m = { id: modelIdCounter, name, qtyMap: {}, positions: positions.map((p, i) => ({ id: modelIdCounter * 1000 + i, ...p })) };
            models.push(m);
        }
    });

    // Sync inventory
    models.forEach(m => m.positions.forEach(p => {
        if (p.glueModel && p.gluePartNo) {
            const k = p.glueModel + '|' + p.gluePartNo;
            if (!inventory[k]) inventory[k] = { glueModel: p.glueModel, gluePartNo: p.gluePartNo, glueDesc: p.glueDesc, containerSize: p.containerSize, stockMap: {} };
        }
    }));

    closeBOMImport(); refreshAll();
    let info = 'BOM导入成功，涉及 ' + Object.keys(modelPosMap).length + ' 个机型';
    if (errors.length) info += '，' + errors.length + ' 行跳过';
    showToast(info);
}

function handleBOMFileSelect(ev) { if (ev.target.files[0]) handleBOMFile(ev.target.files[0]); }
function handleBOMFile(file) {
    const r = new FileReader();
    r.onload = function(ev) {
        document.getElementById('bomGlueCsv').value = ev.target.result.trim();
        switchTab('bom-paste', document.querySelector('#bomImportModal .modal-tab'));
        showToast('BOM文件已加载，请确认后导入');
    };
    r.readAsText(file, 'UTF-8');
}

// ==================== INVENTORY IMPORT ====================
function openImportInventory() {
    document.getElementById('invImportMonthLabel').textContent = formatMonthDisplay(currentMonth);
    document.getElementById('invImportModal').classList.add('open');
}
function closeInvImport() { document.getElementById('invImportModal').classList.remove('open'); document.getElementById('invImportMsg').innerHTML = ''; document.getElementById('invFileMsg').innerHTML = ''; }
function downloadInvTemplate() {
    const csv = '胶水型号,胶水料号,当前库存(支/桶)\nAP1536,M.301.01.00062,150\nAP1908B,M.301.01.00067,80';
    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = '库存盘点_导入模板.csv'; a.click();
    showToast('库存模板已下载');
}

function doImportInventory() {
    const raw = document.getElementById('invCsvInput').value.trim();
    const msg = document.getElementById('invImportMsg');
    msg.innerHTML = '';
    if (!raw) { msg.innerHTML = '<div class="import-result error">请先粘贴库存数据</div>'; return; }
    const lines = raw.split(/\r?\n/).filter(l => l.trim() && !l.startsWith('胶水型号'));
    const errors = [];
    let count = 0;
    lines.forEach((line, idx) => {
        const parts = line.split(',').map(s => s.trim());
        if (parts.length < 3) { errors.push('第'+(idx+1)+'行格式错误'); return; }
        const [glueModel, gluePartNo, stockStr] = parts;
        const stock = parseInt(stockStr, 10);
        if (!glueModel || !gluePartNo) { errors.push('第'+(idx+1)+'行：型号或料号为空'); return; }
        if (isNaN(stock) || stock < 0) { errors.push('第'+(idx+1)+'行('+glueModel+')：库存数无效'); return; }
        const key = glueModel + '|' + gluePartNo;
        if (inventory[key]) {
            setMonthStock(inventory[key], stock);
        } else {
            inventory[key] = { glueModel, gluePartNo, glueDesc: '', containerSize: 0, stockMap: {} };
            setMonthStock(inventory[key], stock);
        }
        count++;
    });
    closeInvImport(); refreshAll();
    let info = '库存导入成功，更新 ' + count + ' 项';
    if (errors.length) info += '，' + errors.length + ' 行跳过';
    showToast(info);
}

function handleInvFileSelect(ev) { if (ev.target.files[0]) handleInvFile(ev.target.files[0]); }
function handleInvFile(file) {
    const r = new FileReader();
    r.onload = function(ev) {
        document.getElementById('invCsvInput').value = ev.target.result.trim();
        switchTab('inv-paste', document.querySelector('#invImportModal .modal-tab'));
        showToast('库存文件已加载，请确认后导入');
    };
    r.readAsText(file, 'UTF-8');
}

// ==================== MODAL TABS ====================
function switchTab(tabId, el) {
    const modal = el.closest('.modal');
    modal.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    modal.querySelectorAll('.import-tab-content').forEach(c => c.classList.remove('active'));
    document.getElementById(tabId).classList.add('active');
}

// ==================== DROP ZONES ====================
document.addEventListener('DOMContentLoaded', () => {
    const bomDropZone = document.getElementById('bomDropZone');
    if (bomDropZone) {
        bomDropZone.addEventListener('click', () => document.getElementById('bomFileInput').click());
        bomDropZone.addEventListener('dragover', e => { e.preventDefault(); bomDropZone.classList.add('dragover'); });
        bomDropZone.addEventListener('dragleave', () => bomDropZone.classList.remove('dragover'));
        bomDropZone.addEventListener('drop', e => { e.preventDefault(); bomDropZone.classList.remove('dragover'); handleBOMFile(e.dataTransfer.files[0]); });
    }
    const invDropZone = document.getElementById('invDropZone');
    if (invDropZone) {
        invDropZone.addEventListener('click', () => document.getElementById('invFileInput').click());
        invDropZone.addEventListener('dragover', e => { e.preventDefault(); invDropZone.classList.add('dragover'); });
        invDropZone.addEventListener('dragleave', () => invDropZone.classList.remove('dragover'));
        invDropZone.addEventListener('drop', e => { e.preventDefault(); invDropZone.classList.remove('dragover'); handleInvFile(e.dataTransfer.files[0]); });
    }
    const prodDropZone = document.getElementById('prodDropZone');
    if (prodDropZone) {
        prodDropZone.addEventListener('click', () => document.getElementById('prodFileInput').click());
        prodDropZone.addEventListener('dragover', e => { e.preventDefault(); prodDropZone.classList.add('dragover'); });
        prodDropZone.addEventListener('dragleave', () => prodDropZone.classList.remove('dragover'));
        prodDropZone.addEventListener('drop', e => { e.preventDefault(); prodDropZone.classList.remove('dragover'); handleProdFile(e.dataTransfer.files[0]); });
    }
});

// ==================== EXPORT ====================
function exportDemandCSV() {
    const demandMap = computeDemand();
    let csv = '\uFEFF胶水需求量_' + currentMonth + '\n\n';
    csv += '胶水型号,胶水料号,胶水描述,规格容量(g),月需求量(精确),月需求量(取整支/桶),涉及机型/位置\n';
    Object.values(demandMap).forEach(d => {
        const involved = d.details.map(x => x.modelName + '/' + x.posName).join('、');
        csv += `"${d.glueModel}","${d.gluePartNo}","${d.glueDesc}",${d.containerSize || 0},${d.totalDemand.toFixed(2)},${d.ceiledDemand || 0},"${involved}"\n`;
    });
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = '胶水需求量_' + currentMonth + '.csv';
    a.click();
    showToast(currentMonth + ' 胶水需求量表已导出');
}

function exportCSV() {
    const demandMap = computeDemand();
    let csv = '\uFEFF胶水采购需求_' + currentMonth + '\n\n';
    csv += '胶水型号,胶水料号,胶水描述,月需求量(精确),月需求量(取整),当前库存(支/桶),建议采购(支/桶),涉及机型/位置\n';
    Object.values(demandMap).forEach(d => {
        const inv = inventory[d.glueModel + '|' + d.gluePartNo];
        const stock = inv ? getMonthStock(inv) : 0;
        const ceiled = d.ceiledDemand || 0;
        const purchase = Math.max(0, ceiled - stock);
        const involved = d.details.map(x => x.modelName + '/' + x.posName).join('、');
        csv += `"${d.glueModel}","${d.gluePartNo}","${d.glueDesc}",${d.totalDemand.toFixed(2)},${ceiled},${stock},${purchase},"${involved}"\n`;
    });
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = '胶水采购需求_' + currentMonth + '.csv';
    a.click();
    showToast(currentMonth + ' 采购需求 CSV 已导出');
}

// ==================== UTILS ====================
function escHtml(s) { if (!s && s !== 0) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function escAttr(s) { return String(s).replace(/'/g,"\\'").replace(/"/g,'&quot;'); }

function showToast(text) {
    const t = document.getElementById('toast');
    t.textContent = text; t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2200);
}

// ==================== START ====================
(function startup() {
    // Check if already logged in (session persistence)
    const sessionUser = getSession();
    if (sessionUser) {
        const users = getUsers();
        if (users[sessionUser]) {
            currentUser = sessionUser;
            document.getElementById('loginOverlay').style.display = 'none';
            updateUserBadge();
            init();
            return;
        }
    }
    // Show login screen
    document.getElementById('loginOverlay').style.display = 'flex';
    showLogin();
})();
</script>
</body>
</html>
